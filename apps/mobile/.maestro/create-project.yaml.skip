# Create Project: Happy Path
appId: com.harpa.pro
tags:
  - smoke
  - projects
---
- runFlow: subflows/ensure-logged-in-mike.yaml

- tapOn:
    id: "btn-new-project"
- waitForAnimationToEnd
- assertVisible: "New Site"

- tapOn:
    id: "input-site-name"
- inputText: "Maestro Test Project"
- tapOn:
    id: "input-site-address"
- inputText: "123 Test Ave, Austin TX"
- tapOn:
    id: "input-client-name"
- inputText: "Test Construction Co."
- hideKeyboard
- tapOn: "Create Site"

- extendedWaitUntil:
    visible: "Sites"
    timeout: 20000
- extendedWaitUntil:
    visible: "Maestro Test Project"
    timeout: 15000
