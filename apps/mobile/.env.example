# Supabase
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key

# Set to "true" to enable demo phone auth in non-__DEV__ builds
# EXPO_PUBLIC_ENABLE_DEV_PHONE_AUTH=false

# CI only — not needed for local dev
# Add EXPO_TOKEN as a GitHub Actions repository secret
# Generate at: https://expo.dev/settings/access-tokens
# EXPO_TOKEN=

# Maestro Cloud — only needed if running `maestro cloud` locally
# Generate at: https://console.mobile.dev/
# MAESTRO_CLOUD_API_KEY=
