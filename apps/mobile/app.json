{
  "expo": {
    "name": "Harpa Pro",
    "slug": "harpa-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "harpa",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f47316"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.harpa.pro",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "Allow Harpa Pro to use the microphone for voice notes."
      }
    },
    "runtimeVersion": "1.0.0",
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#f47316",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.harpa.pro",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-file-system",
        {
          "supportsOpeningDocumentsInPlace": true,
          "enableFileSharing": true
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to use the microphone for voice notes."
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos to attach images to reports.",
          "cameraPermission": "Allow $(PRODUCT_NAME) to use the camera to capture site photos."
        }
      ]
    ],
    "owner": "harpa-pro",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1291d578-e667-4229-9fb1-83b9f95b6ea9"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/1291d578-e667-4229-9fb1-83b9f95b6ea9"
    }
  }
}
