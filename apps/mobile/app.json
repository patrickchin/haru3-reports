{
  "expo": {
    "name": "SiteLog AI",
    "slug": "sitelog-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "sitelog",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f47316"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sitelog.ai",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#f47316",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.sitelog.ai",
      "runtimeVersion": {
        "policy": "sdkVersion"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2b8ccbf4-b4bf-47f3-90c3-e8f5b33f35bd"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/2b8ccbf4-b4bf-47f3-90c3-e8f5b33f35bd"
    }
  }
}
