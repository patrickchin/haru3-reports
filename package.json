{
  "name": "harpa-pro",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev:mobile": "pnpm --filter mobile start",
    "dev:playground": "pnpm --filter playground dev",
    "build:playground": "pnpm --filter playground build",
    "test": "turbo run test",
    "test:mobile": "pnpm --filter mobile test",
    "test:rls:local": "bash scripts/test-rls-local.sh",
    "test:rls:hosted": "pnpm --filter mobile exec vitest run --config ../../supabase/tests/vitest.config.ts --dir ../../supabase/tests",
    "test:e2e:local": "bash scripts/test-e2e-local.sh",
    "fixtures:check": "deno run --allow-env --allow-read supabase/functions/generate-report/check-fixture-staleness.ts",
    "fixtures:rebuild-parsed": "deno run --allow-env --allow-read --allow-write supabase/functions/generate-report/capture-fixtures.ts --rebuild-parsed",
    "fixtures:capture": "deno run --allow-env --allow-net --allow-read --allow-write supabase/functions/generate-report/capture-fixtures.ts"
  },
  "devDependencies": {
    "turbo": "^2.5.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "react": "19.2.0",
      "react-dom": "19.2.0",
      "@xmldom/xmldom": ">=0.8.13",
      "node-forge": ">=1.4.0",
      "picomatch@<2.3.2": "^2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "^4.0.4"
    }
  },
  "dependencies": {
    "expo": "~55.0.9",
    "react": "19.2.0",
    "react-native": "0.83.4"
  }
}
