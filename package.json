{
  "name": "harpa-pro",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev:mobile": "pnpm --filter mobile start:go",
    "dev:mobile:client": "pnpm --filter mobile start:dev-client",
    "dev:web": "pnpm --filter web dev",
    "build:web": "pnpm --filter web build",
    "dev:admin": "pnpm --filter admin dev",
    "build:admin": "pnpm --filter admin build",
    "test": "turbo run test",
    "test:admin": "pnpm --filter admin test",
    "test:mobile": "pnpm --filter mobile test"
  },
  "devDependencies": {
    "turbo": "^2.5.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "react": "19.2.0",
      "react-dom": "19.2.0"
    }
  },
  "dependencies": {
    "expo": "~55.0.9",
    "react": "19.2.0",
    "react-native": "0.83.4"
  }
}
