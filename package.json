{
  "name": "harpa-pro",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev:mobile": "pnpm --filter mobile start:go",
    "dev:mobile:client": "pnpm --filter mobile start:dev-client",
    "dev:playground": "pnpm --filter playground dev",
    "build:playground": "pnpm --filter playground build",
    "test": "turbo run test",
    "test:mobile": "pnpm --filter mobile test"
  },
  "devDependencies": {
    "turbo": "^2.5.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "react": "19.2.0",
      "react-dom": "19.2.0",
      "@xmldom/xmldom": ">=0.8.13",
      "node-forge": ">=1.4.0",
      "picomatch@<2.3.2": "^2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "^4.0.4"
    }
  },
  "dependencies": {
    "expo": "~55.0.9",
    "react": "19.2.0",
    "react-native": "0.83.4"
  }
}
