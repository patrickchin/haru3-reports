# Local Maestro / fixture-mode env file.
#
# Copy or symlink to the location used by `supabase functions serve` when you
# want the generate-report and transcribe-audio edge functions to serve
# canned fixtures instead of calling real providers:
#
#   supabase functions serve \
#     --env-file supabase/.env.fixtures \
#     --no-verify-jwt
#
# No provider API keys are read in this mode (no LLM, no transcription).

USE_FIXTURES=true

# Simulated latency for fixture mode (LLM + transcription). Defaults to
# 5000ms so loading states are visible during local Maestro / manual runs.
# Set to 0 for fast iteration.
FIXTURES_DELAY_MS=5000

# AI_PROVIDER is still consulted when the request body doesn't override it.
# In USE_FIXTURES mode the value only flows through to the response metadata —
# no actual call is made to the provider.
AI_PROVIDER=kimi
