# Local Maestro / fixture-mode env file.
#
# Copy or symlink to the location used by `supabase functions serve` when you
# want the generate-report edge function to serve captured LLM fixtures
# instead of calling a real provider:
#
#   USE_FIXTURES=true \
#     supabase functions serve generate-report \
#     --env-file supabase/.env.fixtures
#
# No provider API keys are read in this mode.

USE_FIXTURES=true

# AI_PROVIDER is still consulted when the request body doesn't override it.
# In USE_FIXTURES mode the value only flows through to the response metadata —
# no actual call is made to the provider.
AI_PROVIDER=kimi
