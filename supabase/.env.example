# Edge function secrets — set these with `supabase secrets set` for remote projects
# Locally these are not needed (Supabase local dev injects its own service keys)

# AI provider for report generation (kimi | openai | anthropic | google)
AI_PROVIDER=kimi

# LLM API Keys (only the one matching AI_PROVIDER is required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
MOONSHOT_API_KEY=

# Twilio — required for WhatsApp OTP authentication
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGE_SERVICE_SID=
